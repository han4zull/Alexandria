<!doctype html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <title>Laporan Pengembalian Selesai - Perpustakaan Alexandria</title>
    <style>
        @page {
            margin: 1in 0.75in 0.75in 0.75in;
            size: A4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Times New Roman', 'Arial', sans-serif;
            font-size: 11pt;
            color: #2c3e50;
            line-height: 1.5;
        }

        .container {
            width: 100%;
            max-width: 210mm;
        }

        /* Company Header */
        .company-header {
            border-bottom: 4px solid #2c3e50;
            padding-bottom: 20pt;
            margin-bottom: 25pt;
            text-align: center;
            background: linear-gradient(135deg, #ecf0f1 0%, #bdc3c7 100%);
            padding: 20pt;
            border-radius: 10pt;
        }

        .company-name {
            font-size: 24pt;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 8pt;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        .company-tagline {
            font-size: 14pt;
            color: #34495e;
            margin-bottom: 10pt;
            font-style: italic;
        }

        .company-info {
            font-size: 10pt;
            color: #7f8c8d;
            line-height: 1.5;
        }

        .company-address {
            margin-top: 10pt;
            font-size: 9pt;
            color: #95a5a6;
        }

        .company-info {
            font-size: 9pt;
            color: #95a5a6;
            line-height: 1.3;
        }

        /* Report Header */
        .report-header {
            background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
            color: white;
            padding: 12pt 15pt;
            margin-bottom: 20pt;
            border-radius: 5pt;
            text-align: center;
        }

        .report-title {
            font-size: 16pt;
            font-weight: bold;
            margin-bottom: 3pt;
        }

        .report-subtitle {
            font-size: 11pt;
            opacity: 0.9;
        }

        /* Meta Information */
        .meta-info {
            display: table;
            width: 100%;
            margin-bottom: 20pt;
            border: 1px solid #ecf0f1;
            border-radius: 5pt;
            overflow: hidden;
        }

        .meta-row {
            display: table-row;
        }

        .meta-cell {
            display: table-cell;
            padding: 8pt 12pt;
            border-bottom: 1px solid #ecf0f1;
        }

        .meta-cell:last-child {
            border-left: 1px solid #ecf0f1;
            text-align: right;
        }

        .meta-label {
            font-weight: bold;
            color: #34495e;
            font-size: 9pt;
        }

        .meta-value {
            color: #2c3e50;
            font-size: 9pt;
        }

        /* Statistics Cards */
        .stats-container {
            display: table;
            width: 100%;
            margin-bottom: 20pt;
            border-spacing: 8pt 0;
        }

        .stats-row {
            display: table-row;
        }

        .stat-card {
            display: table-cell;
            background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
            color: white;
            padding: 12pt;
            border-radius: 5pt;
            text-align: center;
            box-shadow: 0 2pt 4pt rgba(0,0,0,0.1);
        }

        .stat-card.denda-card {
            background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        }

        .stat-number {
            font-size: 16pt;
            font-weight: bold;
            margin-bottom: 3pt;
        }

        .stat-label {
            font-size: 10pt;
            opacity: 0.9;
        }

        /* Table Styles */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25pt;
            font-size: 10pt;
            box-shadow: 0 4pt 12pt rgba(0,0,0,0.15);
            border-radius: 8pt;
            overflow: hidden;
            border: 2px solid #34495e;
            table-layout: fixed;
        }

        .data-table th {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            color: white;
            padding: 12pt 8pt;
            text-align: center;
            font-weight: bold;
            font-size: 10pt;
            border: 1px solid #2c3e50;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            word-wrap: break-word;
        }

        .data-table td {
            padding: 10pt 8pt;
            border-bottom: 1px solid #ecf0f1;
            border-left: 1px solid #ecf0f1;
            border-right: 1px solid #ecf0f1;
            text-align: center;
            vertical-align: middle;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .data-table tbody tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        .data-table tbody tr:hover {
            background-color: #e8f4fd;
        }

        .data-table tbody tr:last-child td {
            border-bottom: 2px solid #34495e;
        }

        .no-data {
            text-align: center;
            padding: 30pt;
            color: #95a5a6;
            font-style: italic;
            border: 2px dashed #ecf0f1;
            border-radius: 5pt;
            margin: 20pt 0;
        }

        /* Footer */
        .report-footer {
            margin-top: 30pt;
            padding-top: 15pt;
            border-top: 2px solid #27ae60;
            text-align: center;
            font-size: 8pt;
            color: #95a5a6;
        }

        .signature-section {
            margin-top: 30pt;
            display: table;
            width: 100%;
            border-top: 2px solid #ecf0f1;
            padding-top: 20pt;
        }

        .signature-box {
            display: table-cell;
            text-align: center;
            padding: 30pt 20pt;
            width: 50%;
        }

        .signature-line {
            border-bottom: 2px solid #2c3e50;
            width: 180pt;
            margin: 40pt auto 8pt auto;
            position: relative;
        }

        .signature-line::after {
            content: "(Tanda Tangan)";
            position: absolute;
            bottom: -20pt;
            left: 50%;
            transform: translateX(-50%);
            font-size: 8pt;
            color: #95a5a6;
        }

        .signature-title {
            font-weight: bold;
            color: #2c3e50;
            font-size: 11pt;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .signature-name {
            margin-top: 5pt;
            font-size: 10pt;
            color: #34495e;
        }

        /* Status badges */
        .status-badge {
            display: inline-block;
            padding: 2pt 6pt;
            border-radius: 3pt;
            font-size: 8pt;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-selesai {
            background-color: #27ae60;
            color: white;
        }

        .condition-badge {
            display: inline-block;
            padding: 2pt 6pt;
            border-radius: 3pt;
            font-size: 8pt;
            font-weight: bold;
            text-transform: uppercase;
            margin: 1pt;
        }

        .condition-baik {
            background-color: #27ae60;
            color: white;
        }

        .condition-rusak {
            background-color: #e74c3c;
            color: white;
        }

        .condition-hilang {
            background-color: #9b59b6;
            color: white;
        }

        .denda-amount {
            font-weight: bold;
            color: #e74c3c;
        }

        .denda-zero {
            color: #27ae60;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Company Header -->
        <div class="company-header">
            <div class="company-name">PERPUSTAKAAN ALEXANDRIA</div>
            <div class="company-tagline">Sistem Manajemen Perpustakaan Modern & Terpercaya</div>
            <div class="company-info">
                Jl. Ilmu Pengetahuan No. 123, Jakarta Selatan, DKI Jakarta 12345<br>
                Telp: (021) 1234-5678 | Fax: (021) 1234-5679<br>
                Email: info@alexandria-library.id | Website: www.alexandria-library.id
            </div>
            <div class="company-address">
                Didirikan sejak 2020 | Terakreditasi A | Member of Indonesian Library Association
            </div>
        </div>

        <!-- Report Header -->
        <div class="report-header">
            <div class="report-title">LAPORAN PENGEMBALIAN SELESAI</div>
            <div class="report-subtitle">Data Pengembalian Buku yang Telah Diselesaikan</div>
        </div>

        <!-- Meta Information -->
        <div class="meta-info">
            <div class="meta-row">
                <div class="meta-cell">
                    <div class="meta-label">Tanggal Laporan:</div>
                    <div class="meta-value">{{ date('d F Y') }}</div>
                </div>
                <div class="meta-cell">
                    <div class="meta-label">Waktu Cetak:</div>
                    <div class="meta-value">{{ date('H:i:s') }} WIB</div>
                </div>
            </div>
            <div class="meta-row">
                <div class="meta-cell">
                    <div class="meta-label">Total Data:</div>
                    <div class="meta-value">{{ isset($items) ? $items->count() : 0 }} Record</div>
                </div>
                <div class="meta-cell">
                    <div class="meta-label">Periode:</div>
                    <div class="meta-value">Real-time</div>
                </div>
            </div>
        </div>

        @if(isset($items) && count($items))
        <!-- Statistics -->
        <div class="stats-container">
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-number">{{ $items->count() }}</div>
                    <div class="stat-label">Total Pengembalian</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">{{ $items->where('denda', '>', 0)->count() }}</div>
                    <div class="stat-label">Dengan Denda</div>
                </div>
                <div class="stat-card denda-card">
                    <div class="stat-number">Rp {{ number_format($items->sum('denda'), 0, ',', '.') }}</div>
                    <div class="stat-label">Total Denda</div>
                </div>
            </div>
        </div>

        <!-- Data Table -->
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 5%;">No</th>
                    <th style="width: 18%;">Peminjam</th>
                    <th style="width: 25%;">Judul Buku</th>
                    <th style="width: 15%;">Tanggal Kembali</th>
                    <th style="width: 17%;">Kondisi Buku</th>
                    <th style="width: 15%;">Denda</th>
                    <th style="width: 5%;">Status</th>
                </tr>
            </thead>
            <tbody>
                @forelse($items as $i => $item)
                @php
                    $kondisiArr = $item->kondisi_buku ? array_map('trim', explode(',', $item->kondisi_buku)) : [];
                @endphp
                <tr>
                    <td style="text-align: center; width: 5%;">{{ $i+1 }}</td>
                    <td style="text-align: left; width: 18%;">
                        <strong>{{ $item->peminjaman->user->username ?? '-' }}</strong><br>
                        <small style="color: #7f8c8d;">{{ $item->peminjaman->user->name ?? '-' }}</small>
                    </td>
                    <td style="text-align: left; width: 25%;">
                        <strong>{{ Str::limit($item->peminjaman->buku->judul ?? '-', 30) }}</strong><br>
                        <small style="color: #7f8c8d;">{{ Str::limit($item->peminjaman->buku->penulis ?? '-', 25) }}</small>
                    </td>
                    <td style="text-align: center; width: 15%;">{{ $item->tanggal_kembali ? \Carbon\Carbon::parse($item->tanggal_kembali)->format('d/m/Y') : '-' }}</td>
                    <td style="text-align: center; width: 17%;">
                        @if(!empty($kondisiArr))
                            @foreach($kondisiArr as $kondisi)
                                @if(strtolower($kondisi) == 'baik')
                                    <span class="condition-badge condition-baik">{{ ucfirst($kondisi) }}</span>
                                @elseif(strtolower($kondisi) == 'rusak')
                                    <span class="condition-badge condition-rusak">{{ ucfirst($kondisi) }}</span>
                                @elseif(strtolower($kondisi) == 'hilang')
                                    <span class="condition-badge condition-hilang">{{ ucfirst($kondisi) }}</span>
                                @else
                                    <span class="condition-badge" style="background-color: #95a5a6; color: white;">{{ ucfirst($kondisi) }}</span>
                                @endif
                            @endforeach
                        @else
                            <span class="condition-badge condition-baik">Baik</span>
                        @endif
                    </td>
                    <td style="text-align: right; width: 15%; font-weight: bold;">
                        @if($item->denda > 0)
                            <span class="denda-amount">Rp {{ number_format($item->denda, 0, ',', '.') }}</span>
                        @else
                            <span class="denda-zero">Rp 0</span>
                        @endif
                    </td>
                    <td style="text-align: center; width: 5%;">
                        <span class="status-badge status-selesai">✓</span>
                    </td>
                </tr>
                @empty
                <tr>
                    <td colspan="7">
                        <div class="no-data">
                            Tidak ada data pengembalian selesai untuk ditampilkan
                        </div>
                    </td>
                </tr>
                @endforelse
            </tbody>
        </table>
        @else
        <div class="no-data">
            Tidak ada data pengembalian selesai untuk ditampilkan pada periode ini
        </div>
        @endif

        <!-- Signature Section -->
        <div class="signature-section">
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-title">Petugas Perpustakaan</div>
                <div class="signature-name">(Nama Petugas)</div>
            </div>
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-title">Kepala Perpustakaan</div>
                <div class="signature-name">(Nama Kepala Perpustakaan)</div>
            </div>
        </div>

        <!-- Footer -->
        <div class="report-footer">
            <p><strong>Perpustakaan Alexandria</strong> - Sistem Manajemen Perpustakaan Modern & Terpercaya</p>
            <p>Dokumen ini dicetak secara otomatis pada {{ date('d F Y H:i:s') }} WIB | Halaman 1 dari 1</p>
